/dts-v1/;

/*
 * SPDX-License-Identifier: Apache-2.0 OR MIT
 * Copyright (c) 2026 Via Balaena
 *
 * M5 Arc 5e — the real-Linux capstone device tree.
 *
 * A MINIMAL device tree for a single Linux guest that "owns the machine" under hv-metal's EL2
 * (see docs/ARC-5-M5-GUEST-INTERFACE.md). Only the nodes the guest actually drives are present, so
 * Linux probes ONLY what hv-metal passes through in Stage-2 — no peripheral it can't reach.
 *
 * Derived from the QEMU `virt` (gic-version=3, virtualization=on) device tree, with three changes:
 *   1. psci `method` = "hvc"  (Linux's PSCI HVCs trap to hv-metal's Arc-5c handler; there is no EL3).
 *   2. /memory relocated to 0x4800_0000 (hv-metal owns the low 128 MiB; the guest owns the rest).
 *   3. /chosen carries our bootargs + the initramfs range (initrd-end patched by `cargo xtask
 *      qemu-linux` to start + the initramfs file size).
 *
 * The GICv3 / PL011 / timer reg + interrupt values are the REAL QEMU `virt` addresses, because the
 * guest drives the real hardware (hv-metal maps GICD 0x0800_0000 + GICR 0x080a_0000 + PL011
 * 0x0900_0000 through Stage-2 with HCR_EL2.IMO=0). Addresses here MUST match linux.rs's layout.
 */

/ {
	#address-cells = <0x02>;
	#size-cells = <0x02>;
	compatible = "linux,dummy-virt";
	model = "baleen-metal-guest";
	interrupt-parent = <0x8002>;

	psci {
		compatible = "arm,psci-1.0", "arm,psci-0.2", "arm,psci";
		method = "hvc";
		cpu_off = <0x84000002>;
		cpu_on = <0xc4000003>;
	};

	cpus {
		#address-cells = <0x01>;
		#size-cells = <0x00>;

		cpu@0 {
			device_type = "cpu";
			compatible = "arm,cortex-a57";
			reg = <0x00>;
		};
	};

	/* Guest RAM: 0x4800_0000 .. 0x8000_0000 (896 MiB). hv-metal owns 0x4000_0000..0x4800_0000. */
	memory@48000000 {
		device_type = "memory";
		reg = <0x00 0x48000000 0x00 0x38000000>;
	};

	apb-pclk {
		compatible = "fixed-clock";
		#clock-cells = <0x00>;
		clock-frequency = <0x16e3600>;
		clock-output-names = "clk24mhz";
		phandle = <0x8000>;
	};

	/* GICv3: distributor @ 0x0800_0000 (64 KiB), redistributor @ 0x080a_0000. */
	intc@8000000 {
		compatible = "arm,gic-v3";
		#interrupt-cells = <0x03>;
		interrupt-controller;
		reg = <0x00 0x8000000 0x00 0x10000
		       0x00 0x80a0000 0x00 0xf60000>;
		#redistributor-regions = <0x01>;
		phandle = <0x8002>;
	};

	pl011@9000000 {
		compatible = "arm,pl011", "arm,primecell";
		reg = <0x00 0x9000000 0x00 0x1000>;
		interrupts = <0x00 0x01 0x04>;
		clocks = <0x8000 0x8000>;
		clock-names = "uartclk", "apb_pclk";
	};

	timer {
		compatible = "arm,armv8-timer";
		interrupts = <0x01 0x0d 0x04
		              0x01 0x0e 0x04
		              0x01 0x0b 0x04
		              0x01 0x0a 0x04>;
		always-on;
	};

	chosen {
		stdout-path = "/pl011@9000000";
		bootargs = "earlycon=pl011,0x9000000 console=ttyAMA0 loglevel=8";
		/* initrd loaded at 0x4c00_0000 by `-device loader`; end = start + size, patched by xtask. */
		linux,initrd-start = <0x4c000000>;
		linux,initrd-end = <0x4c000000>;
	};
};
